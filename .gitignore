# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
node_modules
.pnp
.pnp.js
.pnpm-store

# Environment files - CRITICAL: Never commit these
.env
.env.*
!.env.example
!.env.*.example
!.env.*.template
.env.docker
.env.production
.env.local
.env.development.local
.env.test.local
.env.production.local

# Secrets
*.key
*.cert
secrets/

# Testing
coverage

# Turbo
.turbo

# Vercel
.vercel

# Build Outputs
.next/
.next*/
out/
build
dist


# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
.DS_Store
*.pem

# Backups (don't commit database dumps)
backups/
*.sql
*.sql.gz
!packages/db/migrations/*.sql
!docker/*.sql

# Logs
*.log
logs/

# Claude local settings
.claude/

# Local Nextcloud / instance-specific overrides
docker-compose.override.yml
.local-backup/

# Playwright test output
test-results/
