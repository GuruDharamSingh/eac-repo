# ==================================================================
# EAC Network - Environment Configuration
# ==================================================================
# Copy this file to `.env` and update ALL values for your environment.
# On a new server, update the IP/hostname entries to match your setup.
# NEVER commit the actual .env file to version control.
# ==================================================================

# ------------------------------------------------------------------
# Server / Network
# ------------------------------------------------------------------
# The IP or hostname of your server (used to build URLs below)
SERVER_HOST=localhost

# Allowed dev origins for Next.js (comma-separated, e.g. "192.168.1.10:3004,myhost:3004")
ALLOWED_DEV_ORIGINS=

# Redirect URLs for Supabase Auth (comma-separated)
ADDITIONAL_REDIRECT_URLS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004

# ------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=elkdonis_dev
DATABASE_URL=postgresql://postgres:change-me@localhost:5432/elkdonis_dev

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------
# Supabase / GoTrue Auth
# ------------------------------------------------------------------
SUPABASE_URL=http://localhost:9999
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_KEY=replace-with-service-key
JWT_SECRET=replace-with-long-random-string-at-least-32-chars
REALTIME_SECRET=replace-with-longer-random-string-at-least-64-chars
SUPABASE_DB_PASSWORD=supabase_dev_password

# Optional Google OAuth provider settings
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:9999/callback

# Auth settings
SITE_URL=http://localhost:3000
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
JWT_EXPIRY=3600

# ------------------------------------------------------------------
# Nextcloud
# ------------------------------------------------------------------
# Internal URL (Docker network or direct)
NEXTCLOUD_URL=http://nextcloud-nginx:80
# Public URL (accessible from user's browser)
NEXT_PUBLIC_NEXTCLOUD_URL=http://localhost:8080
NEXTCLOUD_PUBLIC_URL=http://localhost:8080
# Production URL (if different)
NEXTCLOUD_PRODUCTION_URL=
# Admin credentials
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me
# OIDC secret for Nextcloud Social Login
NEXTCLOUD_OIDC_SECRET=change-me-to-random-secret
# Webhook secret
NEXTCLOUD_WEBHOOK_SECRET=change-me-to-random-secret
# Auto-provision Nextcloud users from auth signup flow
NEXTCLOUD_AUTO_PROVISION=false
NEXTCLOUD_DEFAULT_GROUP=EAC_Network

# ------------------------------------------------------------------
# App URLs (used in docker-compose and for cross-app links)
# ------------------------------------------------------------------
ADMIN_URL=http://localhost:3000
BLOG_SUNJAY_URL=http://localhost:3001
BLOG_GURU_DHARAM_URL=http://localhost:3002
FORUM_URL=http://localhost:3003
INNER_GATHERING_URL=http://localhost:3004
EAC_URL=http://localhost:3005
REALTIME_URL=ws://localhost:4000/socket

# Browser-reachable Silex editor origin. Dev can use http://localhost:6805;
# production should point at the reverse-proxied editor origin.
SILEX_EDITOR_PUBLIC_URL=http://localhost:6805

# ------------------------------------------------------------------
# Email / SMTP
# ------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@example.com
EMAIL_CLIENT=smtp
SMTP_MAX_FREQUENCY=5s

# Mailer URL paths
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

# ------------------------------------------------------------------
# SendGrid — transactional email (@elkdonis/email package)
# Used by: amrit-canada, elkdonis-arts-collective, ifac
# ------------------------------------------------------------------
SENDGRID_API_KEY=your-sendgrid-api-key
# Verified sender domain — use your SendGrid-authenticated address
EMAIL_FROM=info@em6860.elkdonis-arts.org
# Owner notification recipients (override per-app defaults)
EAC_OWNER_EMAIL=info@elkdonis-arts.org
AMRIT_CANADA_OWNER_EMAIL=gurudharamsingh@gmail.com
IFAC_OWNER_EMAIL=info@ifacgroup.com

# ------------------------------------------------------------------
# pgAdmin (optional)
# ------------------------------------------------------------------
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change-me

# ------------------------------------------------------------------
# S3 Storage (optional - for external media)
# ------------------------------------------------------------------
S3_HOST=
S3_BUCKET=
S3_KEY=
S3_SECRET=
S3_PORT=443
S3_SSL=true
S3_REGION=us-east-1
NEXTCLOUD_DOMAIN=

# Inter-app authentication (for Talk OAuth flow)
INTER_APP_JWT_SECRET=<generate-with-openssl-rand-base64-32>

# Docker Compose project name override
COMPOSE_PROJECT_NAME=eac
