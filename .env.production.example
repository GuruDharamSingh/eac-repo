# ==================================================================
# EAC PRODUCTION ENVIRONMENT CONFIGURATION
# ==================================================================
# This is a TEMPLATE. Copy to .env.production and fill in real values.
# Run: cp .env.production.example .env.production
# Then: ./scripts/generate-secrets.sh (to generate passwords below)
# ==================================================================

# ------------------------------------------------------------------
# CRITICAL: Generate these with ./scripts/generate-secrets.sh
# ------------------------------------------------------------------
POSTGRES_PASSWORD=
JWT_SECRET=
REALTIME_SECRET=
NEXTCLOUD_ADMIN_PASSWORD=
NEXTCLOUD_OIDC_SECRET=
NEXTCLOUD_WEBHOOK_SECRET=
SUPABASE_SERVICE_KEY=

# ------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------
NODE_ENV=production
SERVER_HOST=your-server-ip-address

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_DB=elkdonis_production
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/elkdonis_production

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ------------------------------------------------------------------
# Supabase Auth
# ------------------------------------------------------------------
SUPABASE_URL=https://auth.your-domain.com
NEXT_PUBLIC_SUPABASE_URL=https://auth.your-domain.com
SUPABASE_ANON_KEY=<copy-from-dev>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<copy-from-dev>
SITE_URL=http://${SERVER_HOST}
DISABLE_SIGNUP=false
JWT_EXPIRY=86400

# Optional Google OAuth provider settings
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://auth.your-domain.com/callback

# ------------------------------------------------------------------
# Nextcloud (Will use external instance on production server)
# ------------------------------------------------------------------
NEXTCLOUD_URL=http://nextcloud-nginx:80
NEXTCLOUD_PUBLIC_URL=http://${SERVER_HOST}:8080
NEXT_PUBLIC_NEXTCLOUD_URL=http://${SERVER_HOST}:8080
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_AUTO_PROVISION=false
NEXTCLOUD_DEFAULT_GROUP=EAC_Network

# ------------------------------------------------------------------
# App URLs (Internal Docker Network)
# ------------------------------------------------------------------
ADMIN_URL=http://admin:3000
BLOG_SUNJAY_URL=http://blog-sunjay:3001
BLOG_GURU_DHARAM_URL=http://blog-guru-dharam:3002
FORUM_URL=http://forum:3003
INNER_GATHERING_URL=http://inner-gathering:3004
EAC_URL=http://elkdonis-arts-collective:3005

# ------------------------------------------------------------------
# Public URLs (External Access via Nginx)
# ------------------------------------------------------------------
NEXT_PUBLIC_ADMIN_URL=http://${SERVER_HOST}:3000
NEXT_PUBLIC_BLOG_SUNJAY_URL=http://${SERVER_HOST}:3001
NEXT_PUBLIC_BLOG_GURU_DHARAM_URL=http://${SERVER_HOST}:3002
NEXT_PUBLIC_FORUM_URL=http://${SERVER_HOST}:3003
NEXT_PUBLIC_INNER_GATHERING_URL=http://${SERVER_HOST}:3004
NEXT_PUBLIC_EAC_URL=http://${SERVER_HOST}:3005

# ------------------------------------------------------------------
# Email (Optional - for password reset, notifications)
# ------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_ADMIN_EMAIL=admin@yourdomain.com
